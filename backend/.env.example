# Configuración de Email (Ejemplo)
# Copia este archivo a .env y completa con tus credenciales reales
MAIL_HOST=smtp.ejemplo.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=tu-usuario@dominio.com
MAIL_PASS=tu-contraseña-secreta
MAIL_FROM=no-reply@dominio.com
MAIL_TO=tu-correo-destino@gmail.com

# Configuración de CORS
CORS_ORIGIN=http://localhost:4321
