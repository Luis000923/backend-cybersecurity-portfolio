---
// Technologies extracted from Luis's actual GitHub projects
const languages = [
  { name: 'JavaScript', level: 90, color: '#f7df1e', projects: 4 },
  { name: 'Python', level: 85, color: '#1d4362', projects: 5 },
  { name: 'TypeScript', level: 80, color: '#5b93d2', projects: 3 },
  { name: 'PHP', level: 55, color: '#777bb4', projects: 1 },
  { name: 'HTML/CSS', level: 75, color: '#e34c26', projects: 4 },
];

const backendTech = [
  'Node.js', 'REST APIs', 'Prisma', 'SQLite', 'MySQL', 'Firebase'
];

const frameworksTech = [
  'Express', 'NestJS', 'Flask', 'React', 'TailwindCSS', 'React Native', 'Expo', 'Electron', 'Astro', 'Baileys'
];

const securityTech = [
  'SAST', 'OWASP', 'Análisis estático', 'Detección de vulnerabilidades', 'Input validation', 'Code scanning'
];

const toolsTech = [
  'Git/GitHub', 'Discord.js', 'Selenium', 'Vite', 'TailwindCSS', 'MoviePy', 'Commander'
];

const automationTech = [
  'Web scraping', 'Bots (Discord, WhatsApp)', 'Procesamiento masivo', 'CLI tools', 'Scripts de automatización'
];

// Donut chart data - language distribution across projects
const donutData = [
  { name: 'JavaScript', pct: 30, color: '#f7df1e' },
  { name: 'Python', pct: 32, color: '#1d4362' },
  { name: 'TypeScript', pct: 20, color: '#5b93d2' },
  { name: 'HTML/CSS', pct: 10, color: '#e34c26' },
  { name: 'PHP', pct: 5, color: '#777bb4' },
  { name: 'Otros', pct: 3, color: '#7b8ba3' },
];
---

<section id="skills" class="container py-20 reveal">
  <div class="flex items-center gap-3 mb-10">
    <span class="mono text-xs text-[var(--accent)] tracking-widest uppercase">02</span>
    <span class="w-8 h-px bg-[var(--accent)]/50"></span>
    <h2 class="section-title text-3xl">Tecnologías & Skills</h2>
  </div>

  <!-- Charts row -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
    
    <!-- Bar chart: Language proficiency -->
    <div class="card p-6">
      <h3 class="text-lg font-semibold text-[var(--text-bright)] mb-6 flex items-center gap-2">
        <svg class="w-5 h-5 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
        Lenguajes — Nivel de experiencia
      </h3>
      <div class="space-y-4 stagger" id="lang-bars">
        {languages.map((lang, i) => (
          <div class="lang-bar-item" data-delay={i * 150}>
            <div class="flex justify-between items-baseline mb-1.5">
              <span class="text-sm font-medium text-[var(--text)]">{lang.name}</span>
              <div class="flex items-center gap-2">
                <span class="text-xs text-[var(--muted)] mono">{lang.projects} proyectos</span>
                <span class="text-xs text-[var(--accent)] mono font-semibold">{lang.level}%</span>
              </div>
            </div>
            <div class="skill-bar-track">
              <div 
                class="skill-bar-fill" 
                style={`max-width: ${lang.level}%; background: linear-gradient(90deg, ${lang.color}88, ${lang.color});`}
                data-width={lang.level}
              ></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Donut chart: Language distribution -->
    <div class="card p-6">
      <h3 class="text-lg font-semibold text-[var(--text-bright)] mb-6 flex items-center gap-2">
        <svg class="w-5 h-5 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"></path></svg>
        Distribución en proyectos
      </h3>
      <div class="flex items-center justify-center gap-8 flex-wrap">
        <div class="donut-chart-wrapper">
          <svg viewBox="0 0 200 200" class="w-48 h-48 md:w-56 md:h-56 -rotate-90" id="donut-chart">
            {(() => {
              let cumOffset = 0;
              const circumference = 2 * Math.PI * 70;
              return donutData.map((d) => {
                const dashLength = (d.pct / 100) * circumference;
                const gap = circumference - dashLength;
                const offset = -(cumOffset / 100) * circumference;
                cumOffset += d.pct;
                return (
                  <circle
                    cx="100" cy="100" r="70"
                    fill="none"
                    stroke={d.color}
                    stroke-width="24"
                    stroke-dasharray={`${dashLength} ${gap}`}
                    stroke-dashoffset={offset}
                    class="donut-segment"
                    stroke-linecap="round"
                  />
                );
              });
            })()}
            <circle cx="100" cy="100" r="52" fill="var(--bg-card)" />
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center">
              <span class="block text-2xl font-bold text-[var(--text-bright)] mono">14</span>
              <span class="text-[10px] text-[var(--muted)] uppercase tracking-wider">repos</span>
            </div>
          </div>
        </div>
        
        <!-- Legend -->
        <div class="grid grid-cols-2 gap-x-6 gap-y-2">
          {donutData.map((d) => (
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-sm shrink-0" style={`background: ${d.color};`}></span>
              <span class="text-xs text-[var(--muted)]">{d.name} <span class="mono text-[var(--text)]">{d.pct}%</span></span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Disclaimer note -->
  <div class="mt-8 flex items-start gap-3 p-4 rounded-lg bg-blue-500/5 border border-blue-500/10 max-w-3xl mx-auto reveal">
    <svg class="w-5 h-5 text-blue-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
    <p class="text-xs text-[var(--muted)] leading-relaxed italic">
      Nota: Las estadísticas presentadas se basan exclusivamente en mis <strong>repositorios públicos</strong> de GitHub. El código y los detalles técnicos de mis proyectos en <strong>repositorios privados</strong> se mantienen bajo estricta confidencialidad para proteger la propiedad intelectual de mis clientes.
    </p>
  </div>

  <!-- Tech categories grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 stagger" id="tech-categories">
    <!-- Backend -->
    <div class="card p-5">
      <div class="flex items-center gap-2 mb-4">
        <div class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"></path></svg>
        </div>
        <h3 class="text-sm font-semibold text-[var(--text-bright)]">Backend</h3>
      </div>
      <div class="flex flex-wrap gap-1.5">
        {backendTech.map((t) => <span class="tech-tag">{t}</span>)}
      </div>
    </div>

    <!-- Security -->
    <div class="card p-5">
      <div class="flex items-center gap-2 mb-4">
        <div class="w-8 h-8 rounded-lg bg-red-500/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
        </div>
        <h3 class="text-sm font-semibold text-[var(--text-bright)]">Seguridad</h3>
      </div>
      <div class="flex flex-wrap gap-1.5">
        {securityTech.map((t) => <span class="tech-tag">{t}</span>)}
      </div>
    </div>

    <!-- Tools -->
    <div class="card p-5">
      <div class="flex items-center gap-2 mb-4">
        <div class="w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        </div>
        <h3 class="text-sm font-semibold text-[var(--text-bright)]">Herramientas</h3>
      </div>
      <div class="flex flex-wrap gap-1.5">
        {toolsTech.map((t) => <span class="tech-tag">{t}</span>)}
      </div>
    </div>

    <!-- Frameworks -->
    <div class="card p-5">
      <div class="flex items-center gap-2 mb-4">
        <div class="w-8 h-8 rounded-lg bg-violet-500/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
        </div>
        <h3 class="text-sm font-semibold text-[var(--text-bright)]">Frameworks</h3>
      </div>
      <div class="flex flex-wrap gap-1.5">
        {frameworksTech.map((t) => <span class="tech-tag">{t}</span>)}
      </div>
    </div>

    <!-- Automation -->
    <div class="card p-5">
      <div class="flex items-center gap-2 mb-4">
        <div class="w-8 h-8 rounded-lg bg-amber-500/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <h3 class="text-sm font-semibold text-[var(--text-bright)]">Automatización</h3>
      </div>
      <div class="flex flex-wrap gap-1.5">
        {automationTech.map((t) => <span class="tech-tag">{t}</span>)}
      </div>
    </div>
  </div>
</section>

<style>
  .donut-chart-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
</style>

<script>
  // Animate bars on scroll
  const barsSection = document.getElementById('lang-bars');
  const barsObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const fills = entry.target.querySelectorAll('.skill-bar-fill');
        fills.forEach((fill, i) => {
          setTimeout(() => {
            (fill as HTMLElement).style.animation = 'fillBar 1.2s ease-out forwards';
          }, i * 150);
        });
        barsObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });
  
  if (barsSection) barsObserver.observe(barsSection);
</script>