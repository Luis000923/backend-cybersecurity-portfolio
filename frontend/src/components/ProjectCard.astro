---
const { title, description, tags = [], url = '#', featured = false, isThisSite = false, languages = [], mainTech = [] } = Astro.props;
---

<article class={`card p-6 group relative overflow-hidden ${featured ? 'border-[var(--accent)]/20 bg-gradient-to-br from-[var(--accent)]/5 to-transparent' : ''} ${isThisSite ? 'border-[var(--accent)]/50 ring-1 ring-[var(--accent)]/50' : ''}`}>
  <!-- Featured indicator -->
  {featured && !isThisSite && (
    <div class="absolute top-0 right-0 w-20 h-20 overflow-hidden">
      <div class="absolute top-3 right-[-22px] bg-[var(--accent)] text-[var(--bg-1)] text-[9px] font-bold py-0.5 px-6 rotate-45 uppercase tracking-wider">
        Featured
      </div>
    </div>
  )}

  <!-- This Site indicator -->
  {isThisSite && (
    <div class="absolute top-0 right-0 w-24 h-24 overflow-hidden">
      <div class="absolute top-4 right-[-28px] bg-emerald-500 text-white text-[9px] font-bold py-1 px-8 rotate-45 uppercase tracking-wider shadow-lg shadow-emerald-500/20">
        ESTE SITIO
      </div>
    </div>
  )}

  <header class="flex items-start justify-between gap-3">
    <div class="flex items-center gap-3">
      <!-- Folder icon -->
      <div class="w-10 h-10 rounded-lg bg-[var(--accent)]/10 flex items-center justify-center shrink-0 group-hover:bg-[var(--accent)]/20 transition-colors">
        <svg class="w-5 h-5 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg>
      </div>
      <div>
        <h3 class="font-semibold text-[var(--text-bright)] text-lg group-hover:text-[var(--accent)] transition-colors mono">{title}</h3>
      </div>
    </div>
    
    <!-- GitHub link -->
    <a href={url} target="_blank" rel="noreferrer" class="text-[var(--muted)] hover:text-[var(--accent)] transition-colors shrink-0 p-1" aria-label={`Ver ${title} en GitHub`}>
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
    </a>
  </header>
  
  <p class="mt-3 text-sm text-[var(--muted)] leading-relaxed">{description}</p>
  
  <!-- Languages used -->
  {languages.length > 0 && (
    <div class="mt-4 flex items-center gap-3">
      {languages.map((lang) => (
        <div class="flex items-center gap-1.5">
          <span class={`w-2 h-2 rounded-full ${
            lang === 'JavaScript' ? 'bg-[#f7df1e]' :
            lang === 'Python' ? 'bg-[#1d4362]' :
            lang === 'TypeScript' ? 'bg-[#5b93d2]' :
            lang === 'PHP' ? 'bg-[#777bb4]' :
            lang === 'C++' ? 'bg-[#00599c]' :
            lang === 'HTML' ? 'bg-[#e34c26]' :
            lang === 'CSS' ? 'bg-[#563d7c]' :
            lang === 'Go Template' ? 'bg-[#00add8]' :
            'bg-[var(--muted)]'
          }`}></span>
          <span class="text-[11px] text-[var(--muted)]">{lang}</span>
        </div>
      ))}
    </div>
  )}

  <!-- Tags -->
  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-1.5">
      {tags.map((t) => <span class="tech-tag text-[10px]">{t}</span>)}
    </div>
  )}

  <!-- View link -->
  <div class="mt-5 pt-4 border-t border-[var(--border)]">
    <a href={url} target="_blank" rel="noreferrer" class="text-[var(--accent)] hover:text-emerald-300 text-sm font-medium flex items-center gap-1.5 group/link">
      <span>Ver repositorio</span>
      <svg class="w-3.5 h-3.5 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
    </a>
  </div>
</article>