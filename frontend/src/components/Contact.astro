---

<section id="contact" class="container py-20 reveal">
  <div class="flex items-center gap-3 mb-10">
    <span class="mono text-xs text-[var(--accent)] tracking-widest uppercase">04</span>
    <span class="w-8 h-px bg-[var(--accent)]/50"></span>
    <h2 class="section-title text-3xl">Contacto</h2>
  </div>

  <div class="max-w-2xl mx-auto">
    <div class="card p-8 md:p-10 text-center">
      <div class="w-16 h-16 rounded-2xl bg-[var(--accent)]/10 flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
      </div>
      
      <h3 class="text-xl font-semibold text-[var(--text-bright)] mb-3">¿Interesado en colaborar?</h3>
      <p class="text-[var(--muted)] mb-8 max-w-md mx-auto text-sm leading-relaxed">
        Estoy abierto a nuevas oportunidades, proyectos freelance y colaboraciones. 
        Si tienes una idea o necesitas un desarrollador backend con enfoque en seguridad, escríbeme.
      </p>

      <div class="flex justify-center mb-10">
        <a href="https://wa.me/50370414649" target="_blank" rel="noreferrer" class="flex items-center gap-2 px-6 py-3 border border-[#25D366]/30 bg-[#25D366]/5 hover:bg-[#25D366] text-[#25D366] hover:text-white rounded-full font-semibold transition-all group">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span class="text-sm">WhatsApp: (+503) 7041 4649</span>
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </a>
      </div>

      <!-- Contact form -->
      <form id="contact-form" class="text-left space-y-4 max-w-md mx-auto">
        <div>
          <label for="contact-name" class="text-xs text-[var(--muted)] uppercase tracking-wider mono mb-1.5 block">Nombre</label>
          <input 
            type="text" 
            id="contact-name" 
            name="name" 
            required 
            class="w-full bg-[var(--bg-1)] border border-[var(--border)] rounded-lg px-4 py-2.5 text-sm text-[var(--text)] focus:border-[var(--accent)] focus:ring-1 focus:ring-[var(--accent)] transition-colors outline-none placeholder-[var(--muted)]/50" 
            placeholder="Tu nombre"
          />
        </div>
        <div>
          <label for="contact-email" class="text-xs text-[var(--muted)] uppercase tracking-wider mono mb-1.5 block">Email</label>
          <input 
            type="email" 
            id="contact-email" 
            name="email" 
            required 
            class="w-full bg-[var(--bg-1)] border border-[var(--border)] rounded-lg px-4 py-2.5 text-sm text-[var(--text)] focus:border-[var(--accent)] focus:ring-1 focus:ring-[var(--accent)] transition-colors outline-none placeholder-[var(--muted)]/50" 
            placeholder="tu@email.com"
          />
        </div>
        <div>
          <label for="contact-message" class="text-xs text-[var(--muted)] uppercase tracking-wider mono mb-1.5 block">Mensaje</label>
          <textarea 
            id="contact-message" 
            name="message" 
            required 
            rows="4" 
            class="w-full bg-[var(--bg-1)] border border-[var(--border)] rounded-lg px-4 py-2.5 text-sm text-[var(--text)] focus:border-[var(--accent)] focus:ring-1 focus:ring-[var(--accent)] transition-colors outline-none resize-none placeholder-[var(--muted)]/50" 
            placeholder="Cuéntame sobre tu proyecto o idea..."
          ></textarea>
        </div>
        
        <button type="submit" class="btn-glow w-full justify-center mt-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
          Enviar mensaje
        </button>
        
        <div id="form-feedback" class="hidden text-center text-sm py-2 rounded-lg"></div>
      </form>

      <!-- Social links -->
      <div class="mt-8 pt-6 border-t border-[var(--border)] flex items-center justify-center gap-4">
        <a href="https://wa.me/50370414649" target="_blank" rel="noreferrer" class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center text-[var(--muted)] hover:text-[#25D366] hover:bg-[#25D366]/10 transition-all" aria-label="WhatsApp">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
        <a href="https://github.com/Luis000923" target="_blank" rel="noreferrer" class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center text-[var(--muted)] hover:text-[var(--accent)] hover:bg-[var(--accent)]/10 transition-all" aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <a href="mailto:cruncron@gmail.com" class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center text-[var(--muted)] hover:text-[var(--accent)] hover:bg-[var(--accent)]/10 transition-all" aria-label="Email">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const feedback = document.getElementById('form-feedback');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    
    const apiUrl = import.meta.env.PROD ? '/api/contact' : 'http://127.0.0.1:3000/api/contact';
    console.log('Sending to:', apiUrl);
    try {
      const res = await fetch(apiUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      
      if (feedback) {
        if (res.ok) {
          feedback.textContent = '✓ Mensaje enviado correctamente';
          feedback.className = 'text-center text-sm py-2 rounded-lg bg-emerald-500/10 text-emerald-400';
          form.reset();
        } else {
          feedback.textContent = '✕ Error al enviar. Intenta de nuevo.';
          feedback.className = 'text-center text-sm py-2 rounded-lg bg-red-500/10 text-red-400';
        }
      }
    } catch (err) {
      if (feedback) {
        feedback.textContent = '✕ Error de conexión. Intenta más tarde.';
        feedback.className = 'text-center text-sm py-2 rounded-lg bg-red-500/10 text-red-400';
      }
    }
  });
</script>