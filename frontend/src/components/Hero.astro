---
import VisitorCounter from './VisitorCounter.astro';
---

<section id="hero" class="container pt-32 pb-20 md:pt-40 md:pb-28">
  <div class="flex flex-col-reverse md:flex-row gap-10 md:gap-16 items-center">
    <!-- Text content -->
    <div class="flex-1 max-w-2xl">
      <div class="flex items-center gap-3 mb-6">
        <span class="inline-block w-12 h-px bg-[var(--accent)]"></span>
        <span class="mono text-xs text-[var(--accent)] tracking-widest uppercase">Backend Developer & Cybersecurity</span>
      </div>
      
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-[var(--text-bright)] leading-[1.1]">
        Luis Ernesto<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--accent)] to-emerald-400">Galdámez</span>
      </h1>
      
      <p class="mt-6 text-lg text-[var(--muted)] leading-relaxed max-w-xl font-light">
        Desarrollo soluciones backend <strong class="text-[var(--text)] font-medium">seguras y escalables</strong>. Combino desarrollo con principios de ciberseguridad para crear aplicaciones funcionales, seguras y mantenibles.
      </p>
      
      <div class="mt-8 flex flex-wrap gap-4 items-center">
        <a href="#projects" class="btn-glow">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
          Ver proyectos
        </a>
        <a href="#contact" class="btn-ghost">
          Contactar
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </a>
      </div>

      <!-- Quick stats -->
      <div class="mt-10 flex flex-wrap gap-8">
        <div class="stat-item">
          <span class="block text-2xl font-bold text-[var(--text-bright)] mono">8+</span>
          <span class="text-xs text-[var(--muted)] uppercase tracking-wider">Proyectos</span>
        </div>
        <div class="stat-item">
          <span class="block text-2xl font-bold text-[var(--text-bright)] mono">5+</span>
          <span class="text-xs text-[var(--muted)] uppercase tracking-wider">Lenguajes</span>
        </div>
        <div class="stat-item">
          <span class="block text-2xl font-bold text-[var(--text-bright)] mono">SAST</span>
          <span class="text-xs text-[var(--muted)] uppercase tracking-wider">Seguridad</span>
        </div>
        <button id="hero-star-btn" class="stat-item group text-left hover:opacity-80 transition-all">
          <div class="flex items-center gap-1.5">
            <span id="hero-star-count" class="block text-2xl font-bold text-[var(--text-bright)] mono">—</span>
            <svg id="hero-star-icon" class="w-5 h-5 text-amber-400 opacity-40 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
            </svg>
          </div>
          <span class="text-xs text-[var(--muted)] uppercase tracking-wider">Estrellas</span>
        </button>
      </div>

      <VisitorCounter />
    </div>

<script>
  const starBtn = document.getElementById('hero-star-btn') as HTMLButtonElement;
  const starCount = document.getElementById('hero-star-count');
  const starIcon = document.getElementById('hero-star-icon');
  const API = import.meta.env.PROD ? '/api/stars' : 'http://localhost:3000/api/stars';

  async function loadStars() {
    try {
      const res = await fetch(API);
      if (res.ok) {
        const data = await res.json();
        if (starCount) starCount.textContent = data.total;
      }
    } catch (e) {}
  }

  function updateVotedUI() {
    if (starIcon) {
      starIcon.setAttribute('fill', 'currentColor');
      starIcon.classList.remove('opacity-40');
      starIcon.classList.add('opacity-100');
    }
    if (starBtn) {
      starBtn.title = 'Ya diste tu estrella';
    }
  }

  if (localStorage.getItem('portfolio_starred') === '1') {
    updateVotedUI();
  }

  starBtn?.addEventListener('click', async () => {
    if (localStorage.getItem('portfolio_starred') === '1') return;
    
    starBtn.disabled = true;
    try {
      const res = await fetch(API, { method: 'POST' });
      const data = await res.json();
      if (starCount) starCount.textContent = data.total;
      localStorage.setItem('portfolio_starred', '1');
      updateVotedUI();
    } catch (e) {
      starBtn.disabled = false;
    }
  });

  loadStars();
</script>

    <!-- Profile image -->
    <div class="relative shrink-0">
      <div class="hero-image-wrapper w-48 h-48 md:w-64 md:h-64 relative">
        <!-- Decorative ring -->
        <div class="absolute -inset-3 rounded-full border border-[var(--accent)]/20 animate-pulse"></div>
        <div class="absolute -inset-6 rounded-full border border-[var(--accent)]/10"></div>
        
        <!-- Corner decorations -->
        <div class="absolute -top-8 -right-8 w-16 h-16 border-t border-r border-[var(--accent)]/30 rounded-tr-2xl"></div>
        <div class="absolute -bottom-8 -left-8 w-16 h-16 border-b border-l border-[var(--accent)]/30 rounded-bl-2xl"></div>
        
        <img 
          src="/images/perfil.jpeg" 
          alt="Luis Ernesto Galdámez" 
          class="w-full h-full object-cover rounded-full border-2 border-[var(--border)] relative z-10"
          loading="eager"
        />
        
        <!-- Glow effect -->
        <div class="absolute inset-0 rounded-full bg-gradient-to-br from-[var(--accent)]/10 to-transparent z-20 pointer-events-none"></div>
      </div>
      
      <!-- Status badge -->
      <div class="absolute bottom-2 right-2 z-30 flex items-center gap-1.5 bg-[var(--bg-card)] border border-[var(--border)] rounded-full px-3 py-1.5">
        <span class="w-2 h-2 rounded-full bg-[var(--accent)] animate-pulse"></span>
        <span class="text-xs text-[var(--muted)] mono">disponible</span>
      </div>
    </div>
  </div>
</section>
