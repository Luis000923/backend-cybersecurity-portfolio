---
---

<div id="star-widget" class="flex items-center justify-center gap-3 py-3 px-5 rounded-xl bg-white/3 border border-[var(--border)] w-fit mx-auto">
  <span class="text-xs text-[var(--muted)] mono uppercase tracking-wider">¿Te gustó el portfolio?</span>

  <button
    id="star-btn"
    class="group flex items-center gap-1.5 text-[var(--muted)] hover:text-amber-400 transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
    aria-label="Dar estrella al portfolio"
  >
    <svg id="star-icon" class="w-5 h-5 transition-transform group-hover:scale-125" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
    </svg>
    <span id="star-count" class="text-sm font-semibold mono text-[var(--text-bright)]">—</span>
  </button>
</div>

<script>
  const btn = document.getElementById('star-btn') as HTMLButtonElement;
  const countEl = document.getElementById('star-count');
  const iconEl = document.getElementById('star-icon');
  
  // Use relative path in production (assuming reverse proxy setup), localhost in dev
  const API = import.meta.env.PROD ? '/api/stars' : 'http://127.0.0.1:3000/api/stars';

  async function loadStars() {
    try {
      const res = await fetch(API);
      if (!res.ok) return;
      const data = await res.json();
      if (countEl) countEl.textContent = String(data.total);
    } catch (_) {}
  }

  // Check if already voted (stored in localStorage as lightweight UX hint)
  const hasVoted = localStorage.getItem('portfolio_starred') === '1';
  if (hasVoted && btn && iconEl) {
    btn.setAttribute('title', 'Ya diste tu estrella');
    iconEl.setAttribute('fill', 'currentColor');
    iconEl.classList.add('text-amber-400');
    btn.classList.remove('hover:text-amber-400');
  }

  btn?.addEventListener('click', async () => {
    if (localStorage.getItem('portfolio_starred') === '1') {
      btn.title = 'Ya diste tu estrella desde este navegador';
      return;
    }

    btn.disabled = true;

    try {
      const res = await fetch(API, { method: 'POST' });
      const data = await res.json();

      if (res.status === 409) {
        // Already voted from this IP
        if (countEl) countEl.textContent = String(data.total);
        btn.title = 'Ya votaste desde esta red';
        if (iconEl) iconEl.setAttribute('fill', '#f59e0b');
        localStorage.setItem('portfolio_starred', '1');
        return;
      }

      if (res.ok) {
        if (countEl) countEl.textContent = String(data.total);
        if (iconEl) {
          iconEl.setAttribute('fill', 'currentColor');
          iconEl.classList.add('text-amber-400', 'scale-125');
          setTimeout(() => iconEl.classList.remove('scale-125'), 300);
        }
        localStorage.setItem('portfolio_starred', '1');
      }
    } catch (_) {
      btn.disabled = false;
    }
  });

  loadStars();
</script>
