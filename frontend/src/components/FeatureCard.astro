---
const { eyebrow, title, text } = Astro.props;
---

<article class="rounded-3xl border border-white/10 bg-white/6 p-5 shadow-[0_24px_60px_-32px_rgba(15,23,42,0.75)] backdrop-blur-sm">
	<p class="text-xs font-semibold uppercase tracking-[0.3em] text-emerald-300">{eyebrow}</p>
	<h2 class="mt-3 text-lg font-medium text-slate-50">{title}</h2>
	<p class="mt-2 text-sm leading-6 text-slate-300">{text}</p>
</article>