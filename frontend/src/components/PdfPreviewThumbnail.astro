---
interface Props {
  url: string;
  name: string;
}

const { url, name } = Astro.props;
const previewId = `pdf-preview-${Math.random().toString(36).substr(2, 9)}`;
---

<div class="pdf-preview-container relative w-full h-full flex items-center justify-center bg-[var(--bg-1)] rounded-lg overflow-hidden" data-preview-id={previewId} data-pdf-url={url}>
  <iframe 
    id={previewId}
    src={url + '#toolbar=0&navpanes=0&scrollbar=0'}
    style="width: 100%; height: 100%; border: none; display: none;"
    allow="usb"
  ></iframe>
  
  <div class="pdf-preview-loading absolute inset-0 flex items-center justify-center bg-[var(--bg-1)]">
    <div class="flex flex-col items-center justify-center gap-3">
      <div class="w-12 h-12 rounded-xl bg-red-500/10 flex items-center justify-center">
        <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
        </svg>
      </div>
      <span class="mono text-xs text-[var(--muted)] uppercase tracking-wider">PDF</span>
    </div>
  </div>
  
  <div class="pdf-preview-error absolute inset-0 flex items-center justify-center bg-[var(--bg-1)] hidden">
    <div class="text-center">
      <svg class="w-10 h-10 text-[var(--danger)] mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <p class="text-xs text-[var(--muted)]">Vista previa no disponible</p>
    </div>
  </div>
</div>

<script type="module" define:vars={{ previewId, url }}>
  // Try to load the PDF preview via iframe
  const iframe = document.getElementById(previewId);
  const container = document.querySelector(`[data-preview-id="${previewId}"]`);
  
  if (iframe && container) {
    // Set timeout to show PDF if it loads
    const loadTimeout = setTimeout(() => {
      // If PDF loaded, hide the icon and show the iframe
      if (iframe.contentDocument || iframe.contentWindow) {
        const loading = container.querySelector('.pdf-preview-loading');
        if (loading) loading.style.display = 'none';
        iframe.style.display = 'block';
      }
    }, 1500);

    iframe.onload = () => {
      clearTimeout(loadTimeout);
      const loading = container.querySelector('.pdf-preview-loading');
      if (loading) loading.style.display = 'none';
      iframe.style.display = 'block';
    };

    iframe.onerror = () => {
      clearTimeout(loadTimeout);
      // PDF view might be blocked, show error message but keep the icon visible
      const loading = container.querySelector('.pdf-preview-loading');
      if (loading) {
        loading.innerHTML = `
          <div class="flex flex-col items-center justify-center gap-3">
            <div class="w-12 h-12 rounded-xl bg-red-500/10 flex items-center justify-center">
              <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
              </svg>
            </div>
            <span class="mono text-xs text-[var(--muted)] uppercase tracking-wider">PDF</span>
          </div>
        `;
      }
    };
  }
</script>

<style>
  .pdf-preview-container {
    background-color: var(--bg-1);
  }
</style>
