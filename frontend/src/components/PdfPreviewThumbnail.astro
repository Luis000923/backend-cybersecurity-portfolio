---
interface Props {
  url: string;
  name: string;
}

const { url, name } = Astro.props;
const previewId = `pdf-preview-${Math.random().toString(36).substr(2, 9)}`;
---

<div class="pdf-preview-container relative w-full h-full" data-preview-id={previewId} data-pdf-url={url}>
  <canvas id={previewId} class="pdf-preview-canvas w-full h-full rounded-lg"></canvas>
  <div class="pdf-preview-loading absolute inset-0 flex items-center justify-center bg-[var(--bg-1)]/50 rounded-lg">
    <div class="flex flex-col items-center justify-center gap-2">
      <div class="w-8 h-8 rounded-lg bg-red-500/10 flex items-center justify-center">
        <svg class="w-4 h-4 text-red-400 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
        </svg>
      </div>
      <span class="mono text-xs text-[var(--muted)] uppercase tracking-wider">Cargando...</span>
    </div>
  </div>
  <div class="pdf-preview-error absolute inset-0 flex items-center justify-center bg-[var(--bg-1)]/80 rounded-lg hidden">
    <div class="text-center">
      <svg class="w-8 h-8 text-[var(--danger)] mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <p class="text-xs text-[var(--muted)]">Error al cargar</p>
    </div>
  </div>
</div>

<script define:vars={{ previewId, url, name }}>
  import * as pdfjsLib from 'pdfjs-dist';

  // Configurar worker
  pdfjsLib.GlobalWorkerOptions.workerSrc = new URL(
    'pdfjs-dist/build/pdf.worker.min.js',
    import.meta.url,
  ).toString();

  class PdfPreviewThumbnail {
    constructor(previewId, url) {
      this.previewId = previewId;
      this.url = url;
      this.renderPreview();
    }

    async renderPreview() {
      try {
        const canvas = document.getElementById(this.previewId);
        if (!canvas) return;

        // Cargar el PDF
        const pdf = await pdfjsLib.getDocument(this.url).promise;
        const page = await pdf.getPage(1); // Get first page

        // Configurar viewport para la vista previa (escala reducida para thumbnail)
        const scale = 1.5; // Escala para buena calidad pero tamaño manejable
        const viewport = page.getViewport({ scale });

        // Configurar canvas
        canvas.width = viewport.width;
        canvas.height = viewport.height;

        const context = canvas.getContext('2d');
        if (!context) throw new Error('Could not get canvas context');

        // Renderizar página
        await page.render({
          canvasContext: context,
          viewport: viewport,
        }).promise;

        // Ocultar loading, mostrar canvas
        const container = document.querySelector(`[data-preview-id="${this.previewId}"]`);
        const loading = container?.querySelector('.pdf-preview-loading');
        if (loading) loading.style.display = 'none';
        
        canvas.style.display = 'block';
      } catch (error) {
        console.error('Error rendering PDF preview:', error);
        const container = document.querySelector(`[data-preview-id="${this.previewId}"]`);
        const loading = container?.querySelector('.pdf-preview-loading');
        const errorDiv = container?.querySelector('.pdf-preview-error');
        
        if (loading) loading.style.display = 'none';
        if (errorDiv) errorDiv.style.display = 'flex';
      }
    }
  }

  // Initialize preview
  new PdfPreviewThumbnail(previewId, url);
</script>

<style>
  .pdf-preview-canvas {
    object-fit: cover;
    box-shadow: inset 0 0 0 1px var(--border);
  }
</style>
